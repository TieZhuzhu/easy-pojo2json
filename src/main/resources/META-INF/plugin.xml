<idea-plugin>
    <id>com.augustlee.tool.easypojo2json</id>
    <name>Easy POJO to JSON</name>
    <vendor>August Lee</vendor>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>com.intellij.java</depends>
    <depends>com.intellij.properties</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="com.augustlee.tool.easypojo2json.NotificationGroup"
                           displayType="BALLOON"
                           key="com.augustlee.tool.easypojo2json.NotificationGroup"/>
        <applicationService serviceImplementation="com.augustlee.tool.easypojo2json.parser.SettingsState"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.augustlee.tool.easypojo2json.SettingsConfigurable"
                id="com.augustlee.tool.easypojo2json.SettingsConfigurable"
                displayName="Easy POJO To JSON"/>
    </extensions>

    <actions>
        <group id="com.augustlee.tool.easypojo2json.EditorPopupMenuGroup">
            <action class="com.augustlee.tool.easypojo2json.EditorPopupMenuAction"
                    id="com.augustlee.tool.easypojo2json.EditorPopupMenuAction"
                    icon="AllIcons.Json.Object"
                    text="Copy JSON"
                    description="Convert POJO to JSON and copy to the clipboard">
            </action>
            <action class="com.augustlee.tool.easypojo2json.EditorPopupMenuWithCommentAction"
                    id="com.augustlee.tool.easypojo2json.EditorPopupMenuWithCommentAction"
                    icon="AllIcons.Json.Object"
                    text="Copy JSON With JavaDoc"
                    description="Convert POJO to JSON with field JavaDoc and copy to the clipboard">
            </action>
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="Copy.Paste.Special"/>
        </group>

        <group id="com.augustlee.tool.easypojo2json.GenerateGroup">
            <action class="com.augustlee.tool.easypojo2json.EditorPopupMenuAction"
                    id="com.augustlee.tool.easypojo2json.GenerateGroupAction"
                    icon="AllIcons.Json.Object"
                    text="Copy JSON"
                    description="Convert POJO to JSON and copy to the clipboard">
            </action>
            <action class="com.augustlee.tool.easypojo2json.EditorPopupMenuWithCommentAction"
                    id="com.augustlee.tool.easypojo2json.GenerateGroupWithCommentAction"
                    icon="AllIcons.Json.Object"
                    text="Copy JSON With JavaDoc"
                    description="Convert POJO to JSON with field JavaDoc and copy to the clipboard">
            </action>
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </group>

        <group id="com.augustlee.tool.easypojo2json.ProjectViewPopupMenuGroup">
            <action class="com.augustlee.tool.easypojo2json.ProjectViewPopupMenuAction"
                    id="com.augustlee.tool.easypojo2json.ProjectViewPopupMenuAction"
                    icon="AllIcons.Json.Object"
                    text="Copy JSON"
                    description="Convert POJO to JSON and copy to the clipboard">
            </action>
            <add-to-group group-id="CutCopyPasteGroup" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
